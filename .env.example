# QuizSpark Environment Variables Configuration Template
# Duplicate this file as '.env' and fill in your values.

# The port the Express.js server will run on (Default: 3000)
PORT=3000

# Your Groq API Key for Live AI Mode question generation
# Get one from: https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"
